# Copy to .env and fill values before real sending.
# Keep .env out of git; this file is only a template.

# Required when running: python send_drafts.py --mode resend
RESEND_API_KEY=
OUTREACH_FROM_EMAIL="Industry Mood <admin@industrymood.com>"

# Optional Reply-To override for Resend.
RESEND_REPLY_TO=

# Operational defaults / notes
# Use a configured sending domain or subdomain with SPF, DKIM, and DMARC before real outreach.
